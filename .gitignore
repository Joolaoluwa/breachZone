infra/breach-zone/.terraform/
infra/breach-zone/.terraform.lock.hcl

# Local .terraform directories
**/.terraform/*

# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
!example.tfvars  # allow example files to be committed

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file — commit this to pin provider versions
# .terraform.lock.hcl  ← intentionally NOT ignored

# SSH keys
*.pem
*.key

# Environment variable files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Lambda build artifacts
build/

# Disabled code/archive folders
*.disabled/

# Python cache
__pycache__/
*.pyc